	"segmentProfiles": {
		"demo_autoswitch_profile": {
			"hysteresisPx": 24,
			"rules": [
				{ "minWidthPx": 1000, "layoutId": "pro_max_custom" },
				{ "minWidthPx": 220, "layoutId": "desk_candle_vol_profile" },
				{ "minWidthPx": 0, "layoutId": "desk_candle_only" }
			]
