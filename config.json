			"metricId": "bid",
			"cellBackground": "rgba(36, 38, 44, 0.92)"
		},
		"num_ask_cell": {
			"description": "Ask numbers with neutral dark cell wash.",
			"role": "number",
			"metricId": "ask",
			"cellBackground": "rgba(32, 34, 40, 0.92)"
