			"description": "Total volume per row with readable cell backing.",
			"role": "number",
			"metricId": "vol",
			"cellBackground": "rgba(42, 42, 48, 0.94)"
		},
		"ratio_delta_over_vol": {
			"description": "Compact delta/vol ratio strip between wings.",
			"role": "ratio",
			"metricId": "delta",
			"ratioDenominatorId": "vol"
		}
