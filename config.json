{
	"$schema": "./config.schema.json",
	"schemaVersion": "1.0.0",
	"defaultLayoutId": "pro_max_custom",
	"dataContract": {
		"description": "Metric ids referenced by tracks/columns must exist on each footprint row (values) or be derivable before render.",
		"levelValueKeys": ["bid", "ask", "vol", "delta"],
		"barAggregateKeys": ["open", "high", "low", "close", "volume", "volume_delta"],
		"aliases": {
			"buy_qty": "bid",
			"sell_qty": "ask"
		}
	},
	"productGoals": {
		"timeToFirstGoodChart": "Pick defaultLayoutId or swap id + run compile; merge emitted JSON in app init.",
		"measurableGuardrails": "compile-layout.mjs rejects duplicate layout ids and generic track / weight length mismatch.",
		"userOutcome": "Authors define ordered columns/tracks, explicit data bindings (keys on incoming rows or bar), and optional presentation hints; compiled segmentPlan.json is the renderer-neutral contract."
	},
	"renderingModel": {
		"description": "Two layers: (1) Data — each column declares binding.key (+ optional scope level|bar) so any numeric field name from your pipeline can appear in sequence. (2) Presentation — role/kind maps to a renderer primitive; optional presentation object is preserved in segmentPlan for a fully template-driven engine you plug in later. Today's honeycomb-charts primitives: genericFootprint → histogram | number | ratio | heatmapCell; footprint → number | bar. New primitives = extend your renderer + optionally add compiler mapping.",
		"artifacts": {
			"segmentPlan": "compiled/<layoutId>.segmentPlan.json lists columns in user order with binding + normalized slot snapshot.",
			"lwcPartialOrPreset": "compiled/*.generic.partial.json or *.footprint-preset.v1.json for current TradingView honeycomb-charts merge."
		}
	},
