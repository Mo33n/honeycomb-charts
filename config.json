	"templates": {
		"hist_vol_left_signed": {
			"description": "Left-growing volume histogram; fill follows bid/ask imbalance sign.",
			"role": "histogram",
			"metricId": "vol",
			"grow": "left",
			"colorizeBySign": true
		},
		"hist_delta_right_signed": {
			"description": "Right-growing delta histogram with sign-based colors (order-flow wing).",
			"role": "histogram",
			"metricId": "delta",
			"grow": "right",
			"colorizeBySign": true
		},
		"hist_bid_left": {
			"description": "Bid-only liquidity wing (magenta/blue desk style).",
			"role": "histogram",
			"metricId": "bid",
			"grow": "left",
			"histogramColor": "rgba(236, 72, 153, 0.58)"
		},
		"hist_ask_right": {
			"description": "Ask-only liquidity wing.",
			"role": "histogram",
			"metricId": "ask",
			"grow": "right",
			"histogramColor": "rgba(100, 181, 246, 0.58)"
		},
		"num_bid_cell": {
			"description": "Bid numbers with neutral dark cell wash.",
